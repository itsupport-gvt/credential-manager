# Python
__pycache__/
*.py[oc]
*.pyd
.venv/
wheels/
*.egg-info/

# PyInstaller output
backend/build/
backend/dist/

# SQLite database and user data (never commit)
backend/data/
backend/.env

# Frontend build output (generated by npm run build)
backend/static/

# TypeScript incremental build info
*.tsbuildinfo

# Node dependencies
frontend/node_modules/
electron/node_modules/

# Electron build output
electron/dist/

# Generated icon (built in CI via gen-icon.js or ImageMagick)
electron/icon.ico

# Project memory (Claude Code)
.claude/

# uv / root-level Python project stubs (not part of the app)
pyproject.toml
uv.lock
.python-version

# OS / editor
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/settings.json
