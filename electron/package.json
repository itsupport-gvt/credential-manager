{
  "name": "credential-manager",
  "version": "1.5.0",
  "description": "Credential Manager by Gravity Business Partners",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@azure/msal-node": "^2.16.3",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.gravitybp.credentialmanager",
    "productName": "Credential Manager",
    "win": {
      "target": "nsis",
      "icon": "icon.ico",
      "forceCodeSigning": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "extraResources": [
      {
        "from": "../backend/dist/credential-backend.exe",
        "to": "backend/credential-backend.exe"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "itsupport-gvt",
      "repo": "credential-manager",
      "releaseType": "release"
    }
  }
}
